		"repository": "https://github.com/fuzdev/fuz.dev",
		"scripts": {
			"start": "gro dev",
			"dev": "gro dev",
			"build": "gro build",
			"check": "gro check",
			"test": "gro test",
			"preview": "vite preview",
			"deploy": "gro deploy"
		},
		"type": "module",
		"engines": {
			"node": ">=22.15"
		},
		"devDependencies": {
			"@fuzdev/fuz_code": "^0.45.1",
			"@fuzdev/fuz_css": "^0.53.0",
