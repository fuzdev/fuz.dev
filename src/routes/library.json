			"@types/estree": "^1.0.8",
			"@webref/css": "^8.2.0",
			"eslint": "^9.39.1",
			"eslint-plugin-svelte": "^3.13.1",
			"esm-env": "^1.2.2",
			"magic-string": "^0.30.21",
			"prettier": "^3.7.4",
			"prettier-plugin-svelte": "^3.4.1",
			"svelte": "^5.49.1",
			"svelte-check": "^4.3.6",
			"svelte2tsx": "^0.7.47",
			"tslib": "^2.8.1",
